# Copy to .env.loadtest. Keep real hosted credentials out of source control.

# HTTP target for k6. Use --dev only for localhost targets.
LOADTEST_BASE_URL=https://example-app.azurewebsites.net

# Preferred database connection string for the target database.
# Hosted targets should use the same application database that has Phase 49
# migration 0037_performance_test_runs.sql applied.
LOADTEST_DATABASE_URL=postgresql://user:password@example.postgres.database.azure.com:5432/database

# Alternative split database settings if LOADTEST_DATABASE_URL is omitted.
LOADTEST_DB_HOST=
LOADTEST_DB_PORT=5432
LOADTEST_DB_NAME=
LOADTEST_DB_USER=
LOADTEST_DB_PASSWORD=

# Optional hosted TLS CA, either inline with escaped newlines or as a path
# relative to this file.
LOADTEST_DATABASE_SSL_CA=
LOADTEST_DATABASE_SSL_CA_PATH=

# Optional defaults. CLI flags override these values.
LOADTEST_RUN_KEY=
LOADTEST_PROFILE=smoke
LOADTEST_VUS=1
LOADTEST_DURATION=30s
# Non-smoke k6 profiles use ramping-vus by default. JSON must fit on one line.
LOADTEST_RAMPING_STAGES=[{"duration":"1m","target":10},{"duration":"2m","target":25},{"duration":"2m","target":50},{"duration":"1m","target":0}]
LOADTEST_COMPLETED_ATTEMPTS=12
LOADTEST_SQL_SAMPLE_INTERVAL_MS=5000
LOADTEST_DB_CONCURRENCY=4
LOADTEST_DB_DURATION_SECONDS=30
LOADTEST_APP_DB_POOL_MAX=10
LOADTEST_APP_INSTANCE_COUNT=1

# Optional Admin credentials. If omitted during seed, the harness creates a
# fake load-test admin and records credentials in the ignored manifest.
LOADTEST_ADMIN_EMAIL=
LOADTEST_ADMIN_PASSWORD=

# Safety switches.
# Set true only for intentional localhost development runs, or pass --dev.
LOADTEST_DEV_MODE=false
# Set true only in non-interactive approved hosted test windows, or pass --yes.
LOADTEST_YES=false
