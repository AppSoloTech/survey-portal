# Hosted (Azure) database settings for scripts/migrate-hosted.mjs.
# Copy to .env.prod and fill in real values. .env.prod is gitignored —
# never commit it. This file is read ONLY by the hosted migrator; the
# deployed app keeps using the App Service application settings.

# Either a full connection string...
# HOSTED_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ...or discrete parts (user/password are URL-encoded automatically):
DB_HOST=your-server.postgres.database.azure.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=your-user
DB_PASSWORD=your-password

# Optional custom CA bundle for TLS verification:
# DATABASE_SSL_CA_PATH=path/to/ca.pem

# Public anonymous survey endpoint throttling. Tune in Azure App Service
# settings before sharing anonymous links broadly.
ANONYMOUS_SURVEY_RATE_LIMIT_WINDOW_MS=900000
ANONYMOUS_SURVEY_RATE_LIMIT_MAX=120
# Recommended dedicated secret for encrypting admin-copyable anonymous public-link
# tokens at rest. Defaults to JWT_SECRET when omitted in the deployed app, but
# production should set a separate stable value before creating public links.
ANONYMOUS_LINK_TOKEN_ENCRYPTION_SECRET=

# Email is disabled until an approved provider adapter is implemented.
# Keep production credentials in Azure App Service settings, never in this file.
EMAIL_ENABLED=false
EMAIL_PROVIDER=disabled
EMAIL_FROM_ADDRESS=survey-portal@example.invalid
EMAIL_REPLY_TO_ADDRESS=

# Optional Admin glossary dictionary suggestions. Production should use a
# client-owned Merriam-Webster Collegiate Dictionary API account/key stored in
# Azure App Service settings, not this file.
DICTIONARY_PROVIDER=disabled
MERRIAM_WEBSTER_COLLEGIATE_API_KEY=
