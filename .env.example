NODE_ENV=development
RUN_ENV=dev
PORT=3000
# Defaults to 127.0.0.1 in dev and 0.0.0.0 when RUN_ENV=prod (hosted
# platforms must be able to reach the server from outside the container).
API_HOST=127.0.0.1
# Used when the API builds user-facing links such as anonymous survey URLs and
# password reset URLs.
WEB_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/survey_portal
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/survey_portal
# Dedicated local database for automated API route tests. The test harness
# refuses to run unless the database name contains "test" and never falls
# back to DATABASE_URL.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/survey_portal_test
HOSTED_DATABASE_URL=postgresql://user:password@host:5432/survey_portal
DATABASE_SSL_CA_PATH=
DATABASE_SSL_CA=
# Discrete connection settings are an alternative to the URL forms in both
# dev and prod: the API builds the connection string from DB_* when neither
# HOSTED_DATABASE_URL nor DATABASE_URL (nor LOCAL_DATABASE_URL in dev) is
# set. User and password are URL-encoded automatically.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=survey_portal
DB_USER=postgres
DB_PASSWORD=postgres
JWT_SECRET=replace_with_a_local_development_secret
# Optional dedicated secret for encrypting admin-copyable anonymous public-link
# tokens at rest. Defaults to JWT_SECRET when omitted.
ANONYMOUS_LINK_TOKEN_ENCRYPTION_SECRET=
JWT_EXPIRES_IN=1h
TRUST_PROXY_HOPS=0
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=5
AUTH_REGISTER_RATE_LIMIT_MAX=5
ANONYMOUS_SURVEY_RATE_LIMIT_WINDOW_MS=900000
ANONYMOUS_SURVEY_RATE_LIMIT_MAX=120
# Phase 16 email foundation. Default local behavior is disabled, and the only
# implemented non-sending adapter is EMAIL_PROVIDER=noop for development tests.
# Do not add production credentials here.
EMAIL_ENABLED=false
EMAIL_PROVIDER=disabled
EMAIL_FROM_ADDRESS=survey-portal@example.invalid
EMAIL_REPLY_TO_ADDRESS=
ADMIN_FIRST_NAME=
ADMIN_LAST_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
